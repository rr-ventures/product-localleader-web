---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Local Leader Designs">
  <main class="flex flex-col items-center justify-center min-h-screen bg-gray-50 p-6">
    <div class="max-w-4xl w-full bg-white rounded-2xl shadow-xl p-8 text-center">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Local Leader Designs</h1>
      <p class="text-gray-600 mb-8">7 landing page versions — select one to view:</p>

      <div class="grid gap-4 md:grid-cols-3 lg:grid-cols-4">
        <a href="/v1" class="block p-6 rounded-xl border-2 border-gray-100 hover:border-primary hover:shadow-md transition-all duration-200 group">
          <h2 class="text-xl font-semibold text-gray-800 group-hover:text-primary mb-2">Version 1</h2>
          <p class="text-gray-500 text-sm">Original design with dark mode support and standard layout.</p>
        </a>

        <a href="/v2" class="block p-6 rounded-xl border-2 border-gray-100 hover:border-primary hover:shadow-md transition-all duration-200 group">
          <h2 class="text-xl font-semibold text-gray-800 group-hover:text-primary mb-2">Version 2</h2>
          <p class="text-gray-500 text-sm">Modern design with floating elements and script typography.</p>
        </a>

        <a href="/v3" class="block p-6 rounded-xl border-2 border-gray-100 hover:border-primary hover:shadow-md transition-all duration-200 group">
          <h2 class="text-xl font-semibold text-gray-800 group-hover:text-primary mb-2">Version 3</h2>
          <p class="text-gray-500 text-sm">Clean aesthetic inspired by premium design subscriptions.</p>
        </a>

        <a href="/v4" class="block p-6 rounded-xl border-2 border-gray-100 hover:border-primary hover:shadow-md transition-all duration-200 group">
          <h2 class="text-xl font-semibold text-gray-800 group-hover:text-primary mb-2">Version 4</h2>
          <p class="text-gray-500 text-sm">Dashboard design with floating metric cards and chart.</p>
        </a>

        <a href="/v5" class="block p-6 rounded-xl border-2 border-gray-100 hover:border-primary hover:shadow-md transition-all duration-200 group">
          <h2 class="text-xl font-semibold text-gray-800 group-hover:text-primary mb-2">Version 5</h2>
          <p class="text-gray-500 text-sm">DM Sans + DM Serif Display. Light, clean starter.</p>
        </a>

        <a href="/v6" class="block p-6 rounded-xl border-2 border-gray-100 hover:border-primary hover:shadow-md transition-all duration-200 group">
          <h2 class="text-xl font-semibold text-gray-800 group-hover:text-primary mb-2">Version 6</h2>
          <p class="text-gray-500 text-sm">Dark theme with Plus Jakarta Sans + Lora editorial feel.</p>
        </a>

        <a href="/v7" class="block p-6 rounded-xl border-2 border-gray-100 hover:border-primary hover:shadow-md transition-all duration-200 group">
          <h2 class="text-xl font-semibold text-gray-800 group-hover:text-primary mb-2">Version 7</h2>
          <p class="text-gray-500 text-sm">Space Grotesk + Crimson Pro. Bold experimental starter.</p>
        </a>
      </div>
    </div>
  </main>
</Layout>
