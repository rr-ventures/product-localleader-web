---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/sections/Hero.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Solutions from '../../components/sections/Solutions.astro';
import Pricing from '../../components/sections/Pricing.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CTA from '../../components/sections/CTA.astro';
---

<Layout title="Local Leader — Become the #1 Tradie in Your Area">
  <main class="flex flex-col overflow-x-clip">
    <Hero className="py-10 md:py-16" />
    <Testimonials className="py-10 md:py-16" />
    <Solutions className="pt-10 md:pt-16" />
    <Pricing className="py-10 md:py-16" />
    <FAQ className="py-10 md:py-16" />
    <CTA className="py-10 md:py-16" />
  </main>
</Layout>
