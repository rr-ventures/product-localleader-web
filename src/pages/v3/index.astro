---
import LayoutV3 from '../../layouts/LayoutV3.astro';
---

<LayoutV3 title="Local Leader | Version 3 Scaffold">
  <main class="mx-auto flex min-h-screen w-full max-w-6xl flex-col justify-center px-6 py-20 sm:px-10">
    <div class="max-w-3xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Version 3</p>
      <h1 class="text-5xl font-bold tracking-tight text-slate-900 sm:text-6xl">
        New landing page <span class="font-serif italic">scaffold</span> ready.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        This route is reserved for a fresh Local Leader concept build. The final design will be based on uploaded
        reference material, the March 2026 website build guide, and Local Leader brand assets.
      </p>
    </div>

    <section class="mt-14 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-slate-900">Primary goal</p>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Build enough trust and belief that the tradie books a free strategy session.
        </p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-slate-900">Design inputs</p>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Reference screenshots, branded logos, proof graphics, and Local Leader's updated copy guidance.
        </p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold text-slate-900">Build status</p>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Scaffold only. Content and components will be replaced once the planning pass is complete.
        </p>
      </div>
    </section>
  </main>
</LayoutV3>
