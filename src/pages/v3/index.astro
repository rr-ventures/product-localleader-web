---
import LayoutV3 from '../../layouts/LayoutV3.astro';
import Header from '../../components/v3/Header.astro';
import Hero from '../../components/v3/Hero.astro';
import LogoCloud from '../../components/v3/LogoCloud.astro';
import HowItWorks from '../../components/v3/HowItWorks.astro';
---

<LayoutV3 title="Local Leader | Become the #1 tradie in your area">
  <div class="min-h-screen flex flex-col relative overflow-hidden">
    <!-- Abstract background blob (using the provided hero graphic) -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] translate-x-1/3 -translate-y-1/4 pointer-events-none z-0 opacity-90">
      <img src="/images/hero-v3.jpg" alt="" class="w-full h-full object-cover rounded-full mix-blend-multiply filter blur-[60px]" />
    </div>
    
    <div class="relative z-10 max-w-[1400px] mx-auto w-full px-6 sm:px-12 lg:px-20 pt-8 pb-24">
      <Header />
      <Hero />
      <LogoCloud />
      <HowItWorks />
    </div>
  </div>
</LayoutV3>
