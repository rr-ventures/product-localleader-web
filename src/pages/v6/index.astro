---
import LayoutV6 from '../../layouts/LayoutV6.astro';
import Hero from '../../components/v6/Hero.astro';
---

<LayoutV6 title="Local Leader | Become the #1 tradie in your area">
  <div class="min-h-screen bg-gray-950 overflow-hidden font-['Plus_Jakarta_Sans']">
    <!-- Navigation -->
    <nav class="absolute top-0 left-0 right-0 z-50 pt-6 px-8">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-xl font-bold text-white">Local Leader</span>
        </div>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-400">
          <a href="#services" class="hover:text-white transition-colors">Services</a>
          <a href="#pricing" class="hover:text-white transition-colors">Pricing</a>
          <a href="#about" class="hover:text-white transition-colors">About</a>
        </div>
        <a href="#contact" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-gray-900 bg-white rounded-full hover:bg-gray-100 transition-colors">
          Book Call
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <Hero />

    <!-- Features Section -->
    <section id="services" class="py-20 px-8 bg-gray-900">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-white mb-12 font-['Lora']">How We Get You to #1</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-gray-800 rounded-2xl p-8 border border-gray-700">
            <div class="w-12 h-12 rounded-full bg-blue-900/50 text-blue-400 flex items-center justify-center mb-4 text-xl">1</div>
            <h3 class="text-lg font-semibold text-white mb-2">Top of Google Maps</h3>
            <p class="text-gray-400 text-sm">Rank in the top 3 for local searches so customers find you first.</p>
          </div>
          <div class="bg-gray-800 rounded-2xl p-8 border border-gray-700">
            <div class="w-12 h-12 rounded-full bg-green-900/50 text-green-400 flex items-center justify-center mb-4 text-xl">2</div>
            <h3 class="text-lg font-semibold text-white mb-2">First Page of Google</h3>
            <p class="text-gray-400 text-sm">Organic traffic without ad spend. Real results that compound.</p>
          </div>
          <div class="bg-gray-800 rounded-2xl p-8 border border-gray-700">
            <div class="w-12 h-12 rounded-full bg-yellow-900/50 text-yellow-400 flex items-center justify-center mb-4 text-xl">3</div>
            <h3 class="text-lg font-semibold text-white mb-2">5-Star Review Engine</h3>
            <p class="text-gray-400 text-sm">Automated reviews from happy clients build trust and credibility.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ADD MORE SECTIONS HERE: Pricing, Testimonials, FAQ, CTA, etc. -->
    <!-- Extract new sections into src/components/v6/ as the page grows -->

    <!-- Footer -->
    <footer class="py-8 px-8 border-t border-gray-800">
      <div class="max-w-7xl mx-auto text-center text-sm text-gray-500">
        &copy; 2026 Local Leader. All rights reserved.
      </div>
    </footer>
  </div>
</LayoutV6>
