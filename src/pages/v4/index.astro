---
import LayoutV4 from '../../layouts/LayoutV4.astro';
---

<LayoutV4 title="Local Leader | Become the #1 tradie in your area">
  <div class="min-h-screen bg-[#F4F6F9] overflow-hidden font-sans">
    <!-- Navigation -->
    <nav class="absolute top-0 left-0 right-0 z-50 pt-6 px-8">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-2">
          <img src="/images/logo-v4.jpg" alt="Local Leader" class="h-8 w-8 rounded-full object-cover" />
        </div>
        
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
          <a href="#how-it-works" class="hover:text-gray-900 transition-colors">How it works</a>
          <a href="#services" class="hover:text-gray-900 transition-colors">Services</a>
          <a href="#pricing" class="hover:text-gray-900 transition-colors">Pricing</a>
          <a href="#about" class="hover:text-gray-900 transition-colors">About</a>
        </div>
        
        <div>
          <a href="#contact" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-gray-900 bg-white border border-gray-200 rounded-full hover:bg-gray-50 transition-colors shadow-sm">
            <span class="mr-2">→</span> Book Call
          </a>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="pt-32 pb-20 px-8 relative">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          
          <!-- Left Content -->
          <div class="max-w-xl z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-gray-200 text-xs font-medium text-gray-600 mb-8 shadow-sm">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
              Local SEO Dominance
            </div>
            
            <h1 class="text-6xl lg:text-7xl font-semibold tracking-tight text-[#1A1D20] leading-[1.1] mb-6">
              Become the #1 tradie in your area.
            </h1>
            
            <p class="text-lg text-gray-600 mb-10 leading-relaxed max-w-md">
              Stop chasing work. Start choosing it. We help Australian trade businesses rank at the top of Google Maps and Search.
            </p>
            
            <div class="flex items-center gap-6 mb-12">
              <a href="#contact" class="inline-flex items-center justify-center px-6 py-3.5 text-base font-medium text-white bg-[#2A2E33] rounded-full hover:bg-black transition-colors shadow-md group">
                <span class="w-8 h-8 rounded-full bg-[#D4F870] text-black flex items-center justify-center mr-3 group-hover:bg-[#c4e860] transition-colors">
                  →
                </span>
                Book Your Free Strategy Call
              </a>
              
              <div class="flex items-center gap-3 text-sm text-gray-500">
                <div class="flex -space-x-2">
                  <img src="https://i.pravatar.cc/100?img=11" alt="User" class="w-8 h-8 rounded-full border-2 border-white" />
                  <img src="https://i.pravatar.cc/100?img=12" alt="User" class="w-8 h-8 rounded-full border-2 border-white" />
                  <img src="https://i.pravatar.cc/100?img=13" alt="User" class="w-8 h-8 rounded-full border-2 border-white" />
                </div>
                <span class="text-xs">Trusted by<br/>local tradies</span>
              </div>
            </div>
          </div>
          
          <!-- Right Visual (Hero Image + Floating Cards) -->
          <div class="relative h-[600px] flex items-center justify-center">
            <!-- Main Hero Image (Using the unnamed (1).jpg which we copied to hero-v4.jpg) -->
            <div class="absolute inset-0 z-0">
              <img src="/images/hero-v4.jpg" alt="Tradie Professional" class="w-full h-full object-contain object-right" style="mask-image: linear-gradient(to left, rgba(0,0,0,1) 60%, rgba(0,0,0,0)); -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,1) 60%, rgba(0,0,0,0));" />
            </div>
            
            <!-- Floating Card 1 -->
            <div class="absolute top-1/4 left-0 bg-white/90 backdrop-blur-sm p-5 rounded-2xl shadow-xl border border-white/50 z-20 transform -rotate-6 w-48">
              <div class="text-xs text-gray-500 mb-1 flex justify-between">
                <span>Google Maps</span>
                <span class="text-[#D4F870] bg-black px-1.5 rounded text-[10px]">+Top 3</span>
              </div>
              <div class="text-3xl font-light text-gray-900">#1</div>
              <div class="w-full bg-gray-100 h-1 mt-3 rounded-full overflow-hidden">
                <div class="bg-green-500 h-full w-full"></div>
              </div>
            </div>
            
            <!-- Floating Card 2 -->
            <div class="absolute bottom-1/3 right-10 bg-white/90 backdrop-blur-sm p-5 rounded-2xl shadow-xl border border-white/50 z-20 transform rotate-3 w-48">
              <div class="text-xs text-gray-500 mb-1 flex justify-between">
                <span>New Reviews</span>
                <span class="text-green-500 bg-green-50 px-1.5 rounded text-[10px]">+12/mo</span>
              </div>
              <div class="text-3xl font-light text-gray-900 flex items-center gap-1">
                4.9 <span class="text-yellow-400 text-xl">★</span>
              </div>
              <div class="w-full bg-gray-100 h-1 mt-3 rounded-full overflow-hidden">
                <div class="bg-yellow-400 h-full w-[98%]"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Dashboard/App Visual Section -->
    <section class="pb-32 px-8 relative z-20 -mt-10">
      <div class="max-w-6xl mx-auto">
        <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 p-8 relative overflow-hidden">
          
          <!-- Top Bar of Dashboard -->
          <div class="flex items-center justify-between mb-8 pb-6 border-b border-gray-100">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center">
                <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
              </div>
              <div>
                <h3 class="text-2xl font-semibold text-gray-900">Local Ranking Growth</h3>
                <p class="text-sm text-gray-500 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-green-500"></span> Dominating local search
                </p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="px-4 py-2 rounded-full border border-gray-200 text-sm font-medium text-gray-600">Last 30 days</div>
              <div class="w-10 h-10 rounded-full bg-[#1A1D20] text-white flex items-center justify-center">+</div>
            </div>
          </div>
          
          <!-- Dashboard Content -->
          <div class="grid md:grid-cols-3 gap-8">
            <!-- Main Chart Area -->
            <div class="md:col-span-2 bg-gray-50 rounded-2xl p-6 border border-gray-100">
              <div class="flex justify-between items-start mb-6">
                <div>
                  <div class="text-sm text-gray-500 mb-1">Organic Leads</div>
                  <div class="text-3xl font-semibold text-gray-900">142</div>
                </div>
                <div class="px-2 py-1 bg-white rounded-md text-xs font-medium text-gray-600 border border-gray-200 shadow-sm">
                  +34%
                </div>
              </div>
              
              <!-- Mock Chart -->
              <div class="h-48 flex items-end gap-2">
                {[40, 45, 35, 50, 45, 60, 55, 70, 65, 80, 75, 90, 85, 100, 95, 110, 105, 120, 115, 130, 125, 142].map((height) => (
                  <div class="flex-1 bg-gradient-to-t from-gray-200 to-gray-300 rounded-t-sm" style={`height: ${height/1.5}%`}></div>
                ))}
              </div>
              <div class="flex justify-between text-xs text-gray-400 mt-4">
                <span>Week 1</span>
                <span>Week 2</span>
                <span>Week 3</span>
                <span>Week 4</span>
              </div>
            </div>
            
            <!-- Side Cards -->
            <div class="space-y-4">
              <!-- Pillar 1 -->
              <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
                <div class="w-8 h-8 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center mb-3">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                </div>
                <h4 class="text-sm font-semibold text-gray-900 mb-1">Top of Google Maps</h4>
                <p class="text-xs text-gray-500">Rank in the top 3 for local searches.</p>
              </div>
              
              <!-- Pillar 2 -->
              <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
                <div class="w-8 h-8 rounded-full bg-green-50 text-green-600 flex items-center justify-center mb-3">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <h4 class="text-sm font-semibold text-gray-900 mb-1">First Page of Google</h4>
                <p class="text-xs text-gray-500">Organic traffic without ad spend.</p>
              </div>
              
              <!-- Pillar 3 -->
              <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
                <div class="w-8 h-8 rounded-full bg-yellow-50 text-yellow-600 flex items-center justify-center mb-3">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                </div>
                <h4 class="text-sm font-semibold text-gray-900 mb-1">5-Star Review Engine</h4>
                <p class="text-xs text-gray-500">Automated reviews from happy clients.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</LayoutV4>
