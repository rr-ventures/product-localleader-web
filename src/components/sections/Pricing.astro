---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";
import GradiantText from "../shared/GradiantText.astro";

export interface Props {
  className?: string;
}

const { className } = Astro.props;

const coreIncludes = [
  "Google Maps top 3 positioning",
  "First page of Google Search",
  "5-star review engine",
  "Google Business Profile management",
  "Local citation building",
  "Monthly reporting — plain English",
  "Competitor gap analysis",
  "Priority support",
  "No ad spend required",
  "No lock-in contracts",
];
---

<section id="pricing" class=`${className}`>
  <Container className="space-y-12">
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <Title>
        Simple, <GradiantText>transparent pricing</GradiantText>
      </Title>
      <p class="text-heading-3 md:text-lg">
        One flat monthly price. No hidden extras. No ad budget on top.
      </p>
    </div>

    <div class="max-w-lg mx-auto">
      <div
        class="relative flex flex-col p-10 rounded-3xl bg-slate-900 text-white shadow-2xl shadow-slate-900/20 overflow-hidden"
      >
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#1A73E8] via-blue-400 to-[#34A853]"></div>
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
        
        <div class="relative z-10">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="text-2xl font-bold text-white flex items-center gap-3">
                <svg class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Core
              </h3>
              <p class="text-slate-400 mt-2 text-sm">
                Everything you need to dominate your local area on Google.
              </p>
            </div>
          </div>
          
          <div class="mt-8 flex items-end gap-1">
            <span class="text-6xl font-bold tracking-tight text-white">$999</span>
            <span class="text-slate-400 mb-2 font-medium">/mo</span>
          </div>
          <p class="text-xs text-slate-500 mt-2">AUD · No lock-in · Cancel anytime</p>
        </div>

        <div class="mt-10 relative z-10">
          <a
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full px-6 py-4 rounded-full bg-white text-slate-900 font-bold text-center hover:bg-slate-50 hover:-translate-y-1 hover:shadow-xl transition-all duration-300"
          >
            Book Your Free Strategy Call
          </a>
        </div>

        <ul class="mt-10 flex flex-col gap-4 relative z-10">
          {
            coreIncludes.map((item) => (
              <li class="flex items-start gap-3 text-sm text-slate-300">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Container>
</section>
