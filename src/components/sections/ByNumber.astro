---
import Container from "../shared/Container.astro";
---

<section class="relative mt-12 md:mt-16">
  <Container>
    <div
      class="mx-auto lg:mx-0 p-5 sm:p-6 py-6 sm:py-8 max-w-5xl rounded-3xl bg-box-bg hover:bg-slate-100 border border-box-border shadow-lg shadow-box-shadow md:divide-x divide-box-border grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-8 md:gap-6 lg:gap-12"
    >
      <div class="text-center">
        <h2
          class="font-semibold text-xl sm:text-2xl md:text-4xl text-heading-1"
        >
          30 days
        </h2>
        <p class="mt-2 text-heading-3">First results</p>
      </div>

      <div class="text-center">
        <h2
          class="font-semibold text-xl sm:text-2xl md:text-4xl text-heading-1"
        >
          $0
        </h2>
        <p class="mt-2 text-heading-3">Ad spend required</p>
      </div>

      <div class="text-center">
        <h2
          class="font-semibold text-xl sm:text-2xl md:text-4xl text-heading-1"
        >
          $999
        </h2>
        <p class="mt-2 text-heading-3">Flat per month</p>
      </div>

      <div class="text-center">
        <h2
          class="font-semibold text-xl sm:text-2xl md:text-4xl text-heading-1"
        >
          0
        </h2>
        <p class="mt-2 text-heading-3">Lock-in contracts</p>
      </div>
    </div>
  </Container>
</section>
