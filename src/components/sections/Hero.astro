---
import { Image } from "astro:assets";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import BtnLink from "../shared/BtnLink.astro";
import GradiantText from "../shared/GradiantText.astro";

import mapsBeforeAfter from "../../../public/images/v1-feedback/before-after-maps.png";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section class=`relative pt-32 lg:pt-36 bg-slate-50/50 ${className}`>
  <Container className={"flex flex-col lg:flex-row gap-10 lg:gap-12 items-center"}>
    <div
      class="relative flex flex-col items-center text-center lg:text-left lg:py-7 xl:py-8
        lg:items-start lg:max-w-none max-w-3xl mx-auto lg:mx-0 lg:flex-1 lg:w-1/2"
    >
      <h1
        class="text-4xl/tight sm:text-5xl/tight md:text-6xl/tight xl:text-7xl/tight
             font-bold text-heading-1 tracking-tight"
      >
        Become the <GradiantText>#1 tradie</GradiantText> in your area.
      </h1>
      <Paragraph className="mt-8 text-lg md:text-xl text-heading-3">
        Your phone ringing with jobs you actually want. No ad spend. No chasing
        leads. Just your business showing up first on Google Maps, first on
        Google Search, with more 5-star reviews than anyone else in your area —
        every single month.
      </Paragraph>

      <div class="mt-10 w-full flex flex-col gap-4">
        <div class="flex flex-col sm:flex-row gap-4 lg:justify-start justify-center">
          <BtnLink
            text="Get Your Free Local Ranking Audit"
            href="#cta"
            variant="primary"
            className="text-white text-center shadow-lg shadow-primary/30"
          />
          <a
            href="#cta"
            class="px-8 py-3 rounded-full border border-box-border text-heading-2 font-medium hover:border-primary hover:text-primary hover:bg-white transition-all duration-300 ease-in-out text-center shadow-sm"
          >
            Book a Strategy Call
          </a>
        </div>
      </div>
    </div>

    <div
      class="flex flex-1 lg:w-1/2 relative lg:max-w-none lg:mx-0 mx-auto max-w-3xl justify-center lg:justify-end perspective-1000"
    >
      <div class="relative w-full max-w-lg transform hover:scale-[1.02] transition-transform duration-500 ease-out">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent rounded-3xl blur-3xl -z-10 transform translate-y-4"></div>
        <Image
          src={mapsBeforeAfter}
          alt="Google Maps ranking transformation — before and after Local Leader"
          class="w-full h-auto object-contain drop-shadow-2xl rounded-2xl"
        />
      </div>
    </div>
  </Container>
</section>
