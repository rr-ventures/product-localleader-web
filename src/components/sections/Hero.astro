---
import { Image } from "astro:assets";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import ByNumber from "./ByNumber.astro";
import BtnLink from "../shared/BtnLink.astro";
import ByResult from "./ByResult.astro";
import GradiantText from "../shared/GradiantText.astro";

import myHeroImage3 from "../../assets/images/hero3.jpg";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section class=`relative pt-32 lg:pt-36 ${className}`>
  <Container className={"flex flex-col lg:flex-row gap-10 lg:gap-12"}>
    <div
      class="relative flex flex-col items-center text-center lg:text-left lg:py-7 xl:py-8
        lg:items-start lg:max-w-none max-w-3xl mx-auto lg:mx-0 lg:flex-1 lg:w-1/2"
    >
      <h1
        class="text-3xl/tight sm:text-4xl/tight md:text-5xl/tight xl:text-6xl/tight
             font-bold text-heading-1"
      >
        Become the <GradiantText>#1 tradie</GradiantText> in your area.
      </h1>
      <Paragraph className="mt-8">
        Your phone ringing with jobs you actually want. No ad spend. No chasing
        leads. Just your business showing up first on Google Maps, first on
        Google Search, with more 5-star reviews than anyone else in your area —
        every single month.
      </Paragraph>

      <div class="mt-10 w-full flex flex-col gap-4">
        <div class="flex flex-col sm:flex-row gap-3 lg:justify-start justify-center">
          <BtnLink
            text="Get Your Free Local Ranking Audit"
            href="#cta"
            variant="primary"
            className="text-white text-center"
          />
          <a
            href="#cta"
            class="px-6 py-3 rounded-full border border-box-border text-heading-2 font-medium hover:border-primary hover:text-primary transition duration-300 ease-linear text-center"
          >
            Book a Strategy Call
          </a>
        </div>
        <div class="mx-auto lg:mx-0">
          <ByResult />
        </div>
      </div>
    </div>

    <div
      class="flex flex-1 lg:w-1/2 lg:h-auto relative lg:max-w-none lg:mx-0 mx-auto max-w-3xl"
    >
      <Image
        src={myHeroImage3}
        alt="Tradie business dominating Google"
        width="2350"
        height="2359"
        class="lg:absolute lg:w-full lg:h-full rounded-3xl object-cover lg:max-h-none max-h-96"
      />
    </div>
  </Container>

  <ByNumber />
</section>
