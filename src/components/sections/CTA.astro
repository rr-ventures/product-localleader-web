---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";
import GradiantText from "../shared/GradiantText.astro";
import Paragraph from "../shared/Paragraph.astro";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section id="cta" class=`pb-20 ${className}`>
  <Container>
    <div
      class="w-full relative py-8 md:py-10 px-6 md:px-8 rounded-2xl bg-gradient-to-br from-slate-100 to-zinc-200"
    >
      <div class="mx-auto text-center max-w-xl md:max-w-2xl relative">
        <h1
          class="text-3xl/tight sm:text-4xl/tight md:text-5xl/tight
          font-bold text-heading-1"
        >
          Ready to
          <GradiantText>own your area?</GradiantText>
        </h1>
        <Paragraph className="pt-8 font-medium">
          Most tradies see movement in 30 days. Start with a free look at where you stand on Google — no cost, no obligation.
        </Paragraph>
        <div class="mx-auto max-w-md sm:max-w-xl pt-10 flex flex-col items-center gap-6">
          <a
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            rel="noopener noreferrer"
            class="px-10 py-4 rounded-full bg-primary text-white font-bold text-xl hover:bg-[#172554] transition-all duration-300 ease-in-out text-center shadow-xl shadow-primary/30 hover:shadow-primary/50 hover:-translate-y-1 w-full sm:w-auto"
          >
            Book Your Free Strategy Call
          </a>
          <a
            href="/v1/thank-you"
            class="text-heading-3 font-medium hover:text-primary hover:underline transition"
          >
            Not ready to talk? Request a Free Local Ranking Audit →
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
