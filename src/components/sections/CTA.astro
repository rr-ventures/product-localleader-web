---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";
import GradiantText from "../shared/GradiantText.astro";
import Paragraph from "../shared/Paragraph.astro";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section id="cta" class=`pb-20 ${className}`>
  <Container>
    <div
      class="w-full relative py-8 md:py-10 px-6 md:px-8 rounded-2xl bg-gradient-to-br from-slate-100 to-zinc-200 dark:from-slate-800 dark:to-zinc-800"
    >
      <div class="mx-auto text-center max-w-xl md:max-w-2xl relative">
        <h1
          class="text-3xl/tight sm:text-4xl/tight md:text-5xl/tight
          font-bold text-heading-1"
        >
          Ready to
          <GradiantText>own your area?</GradiantText>
        </h1>
        <Paragraph className="pt-8 font-medium">
          Most tradies see movement in 30 days. Start with a free look at where you stand on Google — no cost, no obligation.
        </Paragraph>
        <div class="mx-auto max-w-md sm:max-w-xl pt-8 flex flex-col items-center gap-4">
          <BtnLink
            text="Get Your Free Local Ranking Audit"
            href="mailto:hello@localleader.au"
            variant="primary"
            className="text-white text-center w-full sm:w-auto"
          />
          <a
            href="mailto:hello@localleader.au"
            class="text-primary font-medium hover:underline transition"
          >
            Already know what you need? Book a Strategy Call →
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
