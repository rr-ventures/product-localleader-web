---
import Container from "../shared/Container.astro";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section class=`${className}`>
  <Container>
    <div
      class="max-w-2xl mx-auto flex flex-col sm:flex-row items-center gap-6 p-8 rounded-2xl bg-box-bg border border-box-border"
    >
      <div
        class="w-16 h-16 rounded-full bg-gradient-to-br from-indigo-500 via-blue-500 to-green-400 flex items-center justify-center text-white font-bold text-2xl flex-shrink-0"
      >
        R
      </div>
      <div>
        <p class="text-heading-2 leading-relaxed">
          <span class="font-semibold text-heading-1">Reece</span> built Local Leader
          because he watched tradies get burned by generic agencies — charged thousands,
          shown dashboards full of jargon, and left with nothing to show for it. Local
          Leader exists to change that. The tradie wins. That's the whole point.
        </p>
        <p class="mt-2 text-heading-3 text-sm">Founder, Local Leader · Australia</p>
      </div>
    </div>
  </Container>
</section>
