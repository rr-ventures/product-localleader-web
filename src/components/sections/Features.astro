---
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";
import GradiantText from "../shared/GradiantText.astro";

const features = [
  { title: "Your business in the Google Maps top 3" },
  { title: "Your name on the first page of Google Search" },
  { title: "Real Google reviews coming in consistently" },
  { title: "A pipeline that fills without chasing leads or running ads" },
  { title: "Rankings that compound over time — you own them" },
  { title: "Monthly reporting in plain English" },
  { title: "Google Business Profile optimised and managed for you" },
  { title: "Local citation building across Australian directories" },
  { title: "Review request system set up and running" },
  { title: "Competitor gap analysis every month" },
  { title: "Priority support — you talk to a human, not a ticket" },
  { title: "No lock-in — stay because it works, not because you're trapped" },
];

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section id="features" class=`${className}`>
  <Container className="">
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <Title>
        What you get for <GradiantText>$999/month</GradiantText>
      </Title>
      <p class="text-heading-3 md:text-lg">
        Everything managed, optimised, and reported every month. You focus on the tools — we handle the rest.
      </p>
    </div>
    <div class="flex flex-row flex-wrap mt-8 gap-y-4">
      {
        features.map((feature) => {
          return (
            <div class="flex items-center text-heading-3 font-medium basis-full md:basis-1/2 lg:basis-1/3 py-1">
              <span class="font-bold rounded-full w-8 h-8 mr-3 text-primary inline-flex justify-center items-center flex-shrink-0">
                &checkmark;
              </span>
              {feature.title}
            </div>
          );
        })
      }
    </div>
  </Container>
</section>
