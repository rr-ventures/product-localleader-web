    name: "Painters",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor" class="w-8 h-8"><path d="M430.1 124.2c-8.9-6.5-18.6-11.9-29-16.1C367.3 95.5 338.7 88 307.4 88H286V48c0-26.5-21.5-48-48-48s-48 21.5-48 48V88H169C75.7 88 0 163.7 0 257c0 93.3 75.7 169 169 169h90c0 8.8-7.2 16-16 16H200c-17.7 0-32 14.3-32 32s14.3 32 32 32h43c44.2 0 80-35.8 80-80v-5.3c32-3.4 61.1-17.5 83.3-39.7C428.1 358.1 448 325.4 448 288.6V220.2c0-35-8.6-68.5-17.9-96zm-109.9 88c0 22.1-17.9 40-40 40s-40-17.9-40-40 17.9-40 40-40 40 17.9 40 40z"/></svg>`,
  },
  {
    name: "Roofers",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill="currentColor" class="w-8 h-8"><path d="M575.8 255.5c0 18-15 32.1-32 32.1l-32 0 .7 160.2c.2 35.5-28.5 64.3-64 64.3l-320 0c-35.3 0-64-28.7-64-64l0-160.2-32 0c-18 0-32-14-32-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 2 21 7L564.8 231.5c8 7 12 15 11 24z"/></svg>`,
  },
  {
    name: "Tilers",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor" class="w-8 h-8"><path d="M0 32C0 14.3 14.3 0 32 0H480c17.7 0 32 14.3 32 32s-14.3 32-32 32V448c17.7 0 32 14.3 32 32s-14.3 32-32 32H32c-17.7 0-32-14.3-32-32s14.3-32 32-32V64C14.3 64 0 49.7 0 32zm96 96v64h64V128H96zm0 128v64h64V256H96zm128-128v64h64V128H224zm0 128v64h64V256H224zm128-128v64h64V128H352zm0 128v64h64V256H352z"/></svg>`,
  },
];

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section class=`${className}`>
  <Container className="space-y-8">
    <div class="text-center max-w-3xl mx-auto">
      <Title>Built for tradies like you.</Title>
      <p class="mt-4 text-heading-3 md:text-lg">
        If your customers search for you on Google, we can make you the obvious choice.
      </p>
    </div>
    <div class="flex justify-center flex-wrap gap-4">
      {
        trades.map((trade) => (
          <div class="p-5 rounded-xl border border-box-border bg-box-bg hover:bg-slate-200 dark:hover:bg-slate-800 flex flex-col items-center gap-3 min-w-[100px] transition duration-200 group">
            <span class="text-heading-3 group-hover:text-primary transition duration-200" set:html={trade.icon} />
            <span class="text-sm font-medium text-heading-2 group-hover:text-heading-1 transition duration-200">
              {trade.name}
            </span>
          </div>
        ))
      }
    </div>
  </Container>
</section>
