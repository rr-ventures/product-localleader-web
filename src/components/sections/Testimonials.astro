---
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";
import GradiantText from "../shared/GradiantText.astro";

const testimonials = [
  {
    quote:
      "Within 8 weeks my phone was ringing with jobs I didn't have to quote against three other blokes for.",
    name: "Dave M.",
    trade: "Electrician",
    location: "Newcastle, NSW",
  },
  {
    quote:
      "I'd been burned by two agencies before. These guys just showed me the data, told me what they'd do, and did it. No BS.",
    name: "Sarah T.",
    trade: "Plumber",
    location: "Gold Coast, QLD",
  },
  {
    quote:
      "We went from 14 Google reviews to 52 in four months. My phone rings before 8am most mornings now.",
    name: "Chris W.",
    trade: "Landscaper",
    location: "Melbourne, VIC",
  },
  {
    quote:
      "Finally someone who speaks my language. No jargon, no fluff. Just results.",
    name: "Jake R.",
    trade: "Concreter",
    location: "Western Sydney, NSW",
  },
];

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section id="reviews" class=`${className}`>
  <Container className="space-y-12">
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <Title>
        Tradies who stopped <GradiantText>chasing work</GradiantText>
      </Title>
      <p class="text-heading-3 md:text-lg">
        Real results from Australian trade businesses.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        testimonials.map((t) => (
          <div class="flex flex-col justify-between p-8 rounded-3xl bg-white shadow-xl shadow-slate-200/50 border border-slate-100 hover:-translate-y-1 transition-transform duration-300">
            <div>
              <svg class="w-8 h-8 text-slate-300 mb-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
              <p class="text-heading-2 text-base leading-relaxed font-medium">
                {t.quote}
              </p>
            </div>
            <div class="mt-8 pt-6 border-t border-slate-100">
              <p class="font-bold text-heading-1 text-sm">{t.name}</p>
              <p class="text-heading-3 text-xs mt-1">
                {t.trade} · {t.location}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
