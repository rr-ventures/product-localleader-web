---
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";
import GradiantText from "../shared/GradiantText.astro";

const testimonials = [
  {
    quote:
      "Within 8 weeks my phone was ringing with jobs I didn't have to quote against three other blokes for.",
    name: "Dave M.",
    trade: "Electrician",
    location: "Newcastle, NSW",
  },
  {
    quote:
      "I'd been burned by two agencies before. These guys just showed me the data, told me what they'd do, and did it. No BS.",
    name: "Sarah T.",
    trade: "Plumber",
    location: "Gold Coast, QLD",
  },
  {
    quote:
      "We went from 14 Google reviews to 52 in four months. My phone rings before 8am most mornings now.",
    name: "Chris W.",
    trade: "Landscaper",
    location: "Melbourne, VIC",
  },
  {
    quote:
      "Finally someone who speaks my language. No jargon, no fluff. Just results.",
    name: "Jake R.",
    trade: "Concreter",
    location: "Western Sydney, NSW",
  },
];

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section id="reviews" class=`${className}`>
  <Container className="space-y-10">
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <Title>
        Tradies who stopped <GradiantText>chasing work</GradiantText>
      </Title>
      <p class="text-heading-3 md:text-lg">
        Real results from Australian trade businesses.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        testimonials.map((t) => (
          <div class="flex flex-col justify-between p-6 rounded-2xl bg-box-bg border border-box-border shadow-md shadow-box-shadow hover:bg-slate-100 dark:hover:bg-slate-800 transition duration-200">
            <div>
              <div class="flex gap-0.5 mb-4">
                {Array(5)
                  .fill(null)
                  .map(() => (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="w-5 h-5 text-yellow-400"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  ))}
              </div>
              <p class="text-heading-2 text-sm leading-relaxed italic">
                &ldquo;{t.quote}&rdquo;
              </p>
            </div>
            <div class="mt-6 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="font-semibold text-heading-1 text-sm">{t.name}</p>
                <p class="text-heading-3 text-xs">
                  {t.trade} · {t.location}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
