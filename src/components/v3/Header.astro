---
import BrandLogo from "../shared/BrandLogo.astro";

const navItems = [
  { href: "/v3#how-it-works", text: "How it Works" },
  { href: "/v3#pricing", text: "Pricing" },
  { href: "/v3#faq", text: "FAQ" },
];
---

<header class="absolute top-0 left-0 z-50 w-full px-5 py-6 sm:px-6 md:px-12">
  <div class="flex items-center justify-between gap-4">
    <BrandLogo href="/v3" size="lg" />

    <nav class="hidden items-center gap-8 md:flex">
      {
        navItems.map((item) => (
          <a href={item.href} class="text-sm font-medium text-slate-600 transition-colors hover:text-slate-900">
            {item.text}
          </a>
        ))
      }
      <a
        href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-slate-800"
      >
        Book Strategy Call
      </a>
    </nav>

    <details class="group relative md:hidden">
      <summary class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-slate-200 bg-white/90 px-4 py-2.5 text-sm font-medium text-slate-900 shadow-sm backdrop-blur transition-shadow hover:shadow-md">
        Menu
        <svg class="h-4 w-4 opacity-50 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6" />
        </svg>
      </summary>

      <div class="absolute right-0 top-full mt-3 w-[min(18rem,calc(100vw-2.5rem))] rounded-[1.5rem] border border-slate-200 bg-white/95 p-4 shadow-xl backdrop-blur">
        <div class="flex flex-col gap-2">
          {
            navItems.map((item) => (
              <a href={item.href} class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 hover:text-slate-900">
                {item.text}
              </a>
            ))
          }
        </div>

        <a
          href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-slate-800"
        >
          Book Strategy Call
        </a>
      </div>
    </details>
  </div>
</header>
