---

<section class="mt-20 lg:mt-32 max-w-2xl relative z-10">
  <!-- Tags -->
  <div class="flex flex-wrap gap-3 mb-8">
    <span class="px-4 py-1.5 bg-white rounded-full text-sm font-medium shadow-sm border border-gray-100">Top of Maps</span>
    <span class="px-4 py-1.5 bg-white rounded-full text-sm font-medium shadow-sm border border-gray-100">First Page Google</span>
    <span class="px-4 py-1.5 bg-white rounded-full text-sm font-medium shadow-sm border border-gray-100">5-Star Reviews</span>
  </div>

  <!-- Headline -->
  <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6 text-gray-900">
    Become the <span class="font-serif italic font-normal">#1 tradie</span><br />
    in your area.
  </h1>

  <!-- Subheadline -->
  <p class="text-lg text-gray-600 mb-10 max-w-md leading-relaxed">
    Stop chasing work. Start choosing it. We help Australian trade businesses dominate their local area so the phone rings with jobs you actually want.
  </p>

  <!-- CTAs -->
  <div class="flex flex-wrap items-center gap-4">
    <a href="#" class="px-8 py-4 bg-black text-white rounded-full font-medium hover:bg-gray-800 transition-colors shadow-lg">
      Book Your Free Strategy Call
    </a>
    
    <div class="flex items-center gap-3 px-2 py-1 bg-white rounded-full shadow-sm border border-gray-100 pr-6">
      <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-200 flex-shrink-0">
        <!-- Placeholder for founder/Reece image -->
        <img src="https://ui-avatars.com/api/?name=Reece&background=random" alt="Reece" class="w-full h-full object-cover" />
      </div>
      <div class="flex flex-col">
        <span class="text-sm font-medium leading-tight">Get Your Free Audit</span>
        <span class="text-xs text-green-600 flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Available now
        </span>
      </div>
    </div>
  </div>
</section>
