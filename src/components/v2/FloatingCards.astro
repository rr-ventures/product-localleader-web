---
const cards = [
  {
    number: "01",
    title: "Top of",
    subtitle: "GOOGLE MAPS",
    icon: "📍",
    rotation: "-rotate-12",
    translateY: "translate-y-4",
    zIndex: "z-10",
  },
  {
    number: "02",
    title: "First Page of",
    subtitle: "GOOGLE",
    icon: "🔍",
    rotation: "-rotate-3",
    translateY: "-translate-y-2",
    zIndex: "z-20",
  },
  {
    number: "03",
    title: "5-Star Review",
    subtitle: "ENGINE",
    icon: "⭐",
    rotation: "rotate-6",
    translateY: "translate-y-2",
    zIndex: "z-30",
  },
  {
    number: "04",
    title: "Dominant",
    subtitle: "BRANDING",
    icon: "💻",
    rotation: "rotate-12",
    translateY: "translate-y-8",
    zIndex: "z-40",
  }
];
---

<section class="relative py-10 pb-32 flex justify-center overflow-hidden">
  <div class="flex flex-wrap justify-center items-center gap-4 md:gap-0 max-w-5xl mx-auto px-4">
    {cards.map((card, index) => (
      <div 
        class={`relative bg-white rounded-3xl p-6 shadow-xl shadow-gray-200/50 border border-gray-100 w-48 md:w-56 aspect-[3/4] flex flex-col justify-between transition-transform duration-500 hover:scale-105 hover:z-50 cursor-pointer
          ${card.rotation} ${card.translateY} ${card.zIndex}
          ${index !== 0 ? 'md:-ml-12' : ''}
        `}
      >
        <div class="flex justify-end">
          <span class="text-gray-300 font-medium text-sm">{card.number}</span>
        </div>
        
        <div class="flex-1 flex items-center justify-center">
          <div class="text-6xl filter drop-shadow-md">{card.icon}</div>
        </div>
        
        <div class="text-center mt-auto">
          <h3 class="text-xl font-bold text-gray-900 leading-tight">{card.title}</h3>
          <p class="text-red-500 font-serif italic text-lg mt-1">{card.subtitle}</p>
        </div>
      </div>
    ))}
  </div>
</section>
