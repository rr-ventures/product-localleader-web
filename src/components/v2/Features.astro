---
---

<section class="py-24 px-4 bg-white" id="features">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 tracking-tight">
        The Standard <br />
        <span class="font-serif italic text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-pink-500 font-normal pr-2">You'll Never</span> Drop
      </h2>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Card 1 -->
      <div class="bg-white rounded-3xl p-8 shadow-xl shadow-gray-200/50 border border-gray-100 flex flex-col h-full">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">
          Top of <br />
          <span class="font-serif italic text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-pink-500 font-normal">Google Maps</span>
        </h3>
        <p class="text-gray-500 mb-8">
          When someone searches "[your trade] near me", we get you in the top 3 spots.
        </p>
        
        <ul class="space-y-4 mb-8 flex-1">
          <li class="flex items-start gap-3 text-sm text-gray-700 font-medium">
            <span class="text-pink-500 mt-0.5">✓</span>
            Dominate the Map Pack
          </li>
          <li class="flex items-start gap-3 text-sm text-gray-700 font-medium">
            <span class="text-pink-500 mt-0.5">✓</span>
            Calls from ready-to-hire locals
          </li>
          <li class="flex items-start gap-3 text-sm text-gray-700 font-medium">
            <span class="text-pink-500 mt-0.5">✓</span>
            No more tyre-kickers
          </li>
        </ul>
        
        <div class="mt-auto text-5xl filter drop-shadow-md">
          📍
        </div>
      </div>

      <!-- Card 2 -->
      <div class="bg-white rounded-3xl p-8 shadow-xl shadow-gray-200/50 border border-gray-100 flex flex-col h-full text-center items-center justify-center relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-b from-gray-50/50 to-white pointer-events-none"></div>
        
        <div class="text-7xl filter drop-shadow-xl mb-12 transform group-hover:scale-110 transition-transform duration-500">
          ⭐
        </div>
        
        <h3 class="text-2xl font-bold text-gray-900 mb-4 relative z-10">
          5-Star <br />
          <span class="font-serif italic text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-red-500 font-normal">Review Engine</span>
        </h3>
        <p class="text-gray-500 relative z-10">
          We build you a system that generates real Google reviews from your happy customers automatically.
        </p>
      </div>

      <!-- Card 3 -->
      <div class="bg-white rounded-3xl p-8 shadow-xl shadow-gray-200/50 border border-gray-100 flex flex-col h-full">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">
          First Page of <br />
          <span class="font-serif italic text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-pink-500 font-normal">Google</span>
        </h3>
        <p class="text-gray-500 mb-8">
          When locals search for your trade in your area, your business shows up first.
        </p>
        
        <ul class="space-y-4 mb-8 flex-1">
          <li class="flex items-start gap-3 text-sm text-gray-700 font-medium">
            <span class="text-pink-500 mt-0.5">✓</span>
            Outrank your competitors
          </li>
          <li class="flex items-start gap-3 text-sm text-gray-700 font-medium">
            <span class="text-pink-500 mt-0.5">✓</span>
            Organic traffic every day
          </li>
          <li class="flex items-start gap-3 text-sm text-gray-700 font-medium">
            <span class="text-pink-500 mt-0.5">✓</span>
            Zero ad spend required
          </li>
        </ul>
        
        <div class="mt-auto text-5xl filter drop-shadow-md">
          🔍
        </div>
      </div>

    </div>
  </div>
</section>
