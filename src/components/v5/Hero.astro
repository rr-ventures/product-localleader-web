---

<section class="relative overflow-x-clip pt-28 pb-20 lg:pt-48 lg:pb-32">
  <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg width=%2740%27 height=%2740%27 viewBox=%270 0 40 40%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cg fill=%27none%27 fill-rule=%27evenodd%27%3E%3Cg fill=%27%23947569%27 fill-opacity=%271%27%3E%3Cpath d=%27M20 0l20 20-20 20L0 20 20 0zm0 5.5L5.5 20 20 34.5 34.5 20 20 5.5z%27/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-100 text-orange-800 text-sm font-medium mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
          </span>
          Taking on new local partners
        </div>
        
        <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-[1.1] mb-6">
          Become the <span class="font-serif italic text-orange-600 font-medium">#1 service provider</span> in your area.
        </h1>
        
        <p class="text-xl text-slate-600 mb-10 leading-relaxed">
          We get you to the top of Google Maps, first page of Google, and build your 5-star reputation — <strong class="font-semibold text-slate-900">no ad spend required.</strong>
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            class="inline-flex justify-center items-center bg-orange-600 text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-orange-700 transition-all hover:-translate-y-0.5 shadow-lg shadow-orange-600/20"
          >
            Book a Free Strategy Session
          </a>
          <a 
            href="/v5/thank-you"
            class="inline-flex justify-center items-center bg-white border-2 border-slate-200 text-slate-700 px-8 py-4 rounded-full font-bold text-lg hover:border-slate-300 hover:bg-slate-50 transition-all"
          >
            Request a Local Ranking Audit
          </a>
        </div>
        
        <div class="mt-8 flex flex-col items-start gap-4 text-sm font-medium text-slate-500 sm:flex-row sm:items-center">
          <div class="flex -space-x-2">
            <!-- Placeholder avatars -->
            <div class="w-8 h-8 rounded-full bg-slate-200 border-2 border-[#fbfaf7] flex items-center justify-center text-xs text-slate-600 font-bold">JM</div>
            <div class="w-8 h-8 rounded-full bg-slate-300 border-2 border-[#fbfaf7] flex items-center justify-center text-xs text-slate-700 font-bold">PT</div>
            <div class="w-8 h-8 rounded-full bg-slate-400 border-2 border-[#fbfaf7] flex items-center justify-center text-xs text-white font-bold">RS</div>
          </div>
          <p>Join 50+ local businesses dominating their market.</p>
        </div>
      </div>
      
      <div class="relative flex items-center justify-center lg:h-[600px]">
        <!-- Floating modules instead of one giant card -->
        <div class="relative w-full max-w-lg mx-auto">
          <div class="absolute inset-0 bg-gradient-to-tr from-orange-200 to-orange-50 rounded-[2.5rem] transform rotate-3 scale-105 opacity-50"></div>
          
          <img 
            src="/images/v5-hero-proof.jpg" 
            alt="Local Leader Performance Dashboard" 
            class="relative z-10 w-full h-auto rounded-3xl shadow-2xl shadow-slate-900/10 border border-white/50 object-cover object-left-top"
            style="clip-path: inset(0 0 15% 0 round 1.5rem);"
          />
          
          <!-- Floating elements to break the box -->
          <div class="absolute left-3 right-3 -bottom-4 z-20 flex items-center gap-3 rounded-2xl border border-slate-100 bg-white p-3 shadow-xl animate-[bounce_4s_infinite] sm:left-4 sm:right-auto sm:-bottom-6 sm:p-4 md:-left-8 md:gap-4">
            <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center text-green-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 font-medium uppercase tracking-wider">Map Ranking</p>
              <p class="text-lg font-bold text-slate-900 sm:text-xl">#1 Position</p>
            </div>
          </div>
          
          <div class="absolute right-3 top-4 z-20 flex items-center gap-3 rounded-2xl border border-slate-100 bg-white p-3 shadow-xl animate-[bounce_5s_infinite_0.5s] sm:right-4 sm:top-8 sm:p-4 md:-right-6 md:top-12 md:gap-4">
            <div>
              <div class="flex items-center gap-1 text-orange-500 mb-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </div>
              <p class="text-sm font-bold text-slate-900">4.9 Average</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
