---
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-50 via-white to-white -z-10"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-sm font-medium mb-8 border border-blue-100">
          <span class="flex h-2 w-2 rounded-full bg-blue-600"></span>
          For Australian Service Providers
        </div>
        
        <h1 class="text-5xl lg:text-6xl font-serif text-slate-900 leading-[1.1] mb-6 tracking-tight">
          Become the <span class="text-blue-600 italic">#1 service provider</span> in your area.
        </h1>
        
        <p class="text-lg text-slate-600 mb-10 leading-relaxed max-w-xl">
          We get you to the top of Google Maps, first page of Google, and build your 5-star reputation — no ad spend required. Stop chasing work and start choosing it.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-full text-white bg-slate-900 hover:bg-slate-800 shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200"
          >
            Book a Free Strategy Session
          </a>
          <a
            href="/v10/thank-you"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-full text-slate-700 bg-white border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all duration-200"
          >
            Request a Local Ranking Audit
          </a>
        </div>
        
        <div class="mt-10 flex items-center gap-4 text-sm text-slate-500">
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-slate-200 border-2 border-white flex items-center justify-center text-xs font-medium text-slate-600">JD</div>
            <div class="w-8 h-8 rounded-full bg-blue-100 border-2 border-white flex items-center justify-center text-xs font-medium text-blue-700">MS</div>
            <div class="w-8 h-8 rounded-full bg-emerald-100 border-2 border-white flex items-center justify-center text-xs font-medium text-emerald-700">TR</div>
          </div>
          <p>Join 50+ local businesses dominating their market</p>
        </div>
      </div>
      
      <div class="relative lg:ml-auto w-full max-w-lg">
        <div class="absolute -inset-4 bg-gradient-to-tr from-blue-100 to-transparent opacity-50 blur-2xl rounded-full"></div>
        <img 
          src="/images/v10-hero.jpg" 
          alt="Local search dominance proof" 
          class="relative rounded-2xl shadow-2xl border border-white/50 w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
