---
import Container from "../shared/Container.astro";
import BrandLogo from "../shared/BrandLogo.astro";

const navItems = [
  { href: "/v10#how-it-works", text: "How it Works" },
  { href: "/v10#pricing", text: "Pricing" },
  { href: "/v10#faq", text: "FAQ" },
];
---

<header class="absolute inset-x-0 top-0 z-50 py-6">
  <Container>
    <nav class="flex items-center justify-between gap-6">
      <div class="min-w-max inline-flex relative">
        <BrandLogo href="/v10" size="lg" className="relative" />
      </div>

      <div class="hidden md:flex items-center gap-8">
        {
          navItems.map((item) => (
            <a href={item.href} class="text-sm font-medium text-slate-600 transition-colors hover:text-slate-900">
              {item.text}
            </a>
          ))
        }
        <a
          href="/v10#book-call"
          class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-slate-900 text-sm font-medium text-white shadow-md transition-all duration-200 hover:-translate-y-0.5 hover:bg-slate-800 hover:shadow-lg"
        >
          Book a Strategy Call
        </a>
      </div>

      <details class="group relative md:hidden">
        <summary class="flex list-none cursor-pointer items-center gap-2 rounded-full border border-slate-200 bg-white/90 px-4 py-2.5 text-sm font-medium text-slate-900 shadow-sm backdrop-blur">
          Menu
          <svg class="h-4 w-4 opacity-60 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6" />
          </svg>
        </summary>

        <div class="absolute right-0 top-full mt-3 w-[min(18rem,calc(100vw-2rem))] rounded-[1.75rem] border border-slate-200 bg-white/95 p-4 shadow-[0_24px_60px_rgba(15,23,42,0.14)] backdrop-blur">
          <div class="flex flex-col gap-2">
            {
              navItems.map((item) => (
                <a href={item.href} class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 hover:text-slate-900">
                  {item.text}
                </a>
              ))
            }
          </div>

          <a
            href="/v10#book-call"
            class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white shadow-md transition-colors hover:bg-slate-800"
          >
            Book a Strategy Call
          </a>
        </div>
      </details>
    </nav>
  </Container>
</header>
