---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-AU" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Local Leader version 10 - Local SEO for Australian service providers."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-white text-slate-900 antialiased selection:bg-slate-900 selection:text-white">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-sans: "Inter", system-ui, sans-serif;
    --font-serif: "Playfair Display", Georgia, serif;
  }

  html {
    font-family: var(--font-sans);
  }

  .font-serif {
    font-family: var(--font-serif);
  }
</style>
