---
import Navbar from "../components/v2/Navbar.astro";
import Footer from "./Footer.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Local Leader helps Australian trade businesses dominate Google Maps, rank first on Google Search, and build a 5-star review engine. $999/month. No lock-in."
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Raleway:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style/custom.css" />
  </head>
  <body class="overflow-hidden overflow-y-auto bg-[#f8f9fa] font-sans">
    <Navbar />
    <slot />
    <Footer />
  </body>
  <script>
    // Always force light mode
    document.documentElement.classList.remove("dark");
    localStorage.setItem("theme", "light");
  </script>
</html>
