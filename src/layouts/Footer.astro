---
import GroupFooterNav from "../components/blocks/GroupFooterNav.astro";
import Container from "../components/shared/Container.astro";
import FooterNav from "../components/shared/FooterNav.astro";
import Paragraph from "../components/shared/Paragraph.astro";

const quickLinks = [
  { itemText: "How It Works", itemLink: "#how-it-works" },
  { itemText: "Services", itemLink: "#services" },
  { itemText: "Pricing", itemLink: "#pricing" },
  { itemText: "Reviews", itemLink: "#reviews" },
  { itemText: "FAQ", itemLink: "#faq" },
];

const getInTouch = [
  { itemText: "Get a Free Audit", itemLink: "/v1/thank-you" },
  { itemText: "Book a Strategy Call", itemLink: "https://calendar.app.google/ceK9b3Jr3KGD9cCs5" },
  { itemText: "Contact Us", itemLink: "mailto:hello@localleader.au" },
];
---

<div class="relative mt-16">
  <span
    class="w-20 h-20 rounded-full bg-gradient-to-br from-sky-500 from-0% via-primary via-80% to-green-600 to-110% absolute left-1/3 bottom-1/3"
  ></span>
  <span
    class="w-40 h-40 rounded-full bg-gradient-to-br from-yellow-400 from-0% via-green-600 via-60% via-sky-700 via-85% to-primary to-100% absolute right-1 top-2/4"
  ></span>
  <span
    class="w-40 h-40 rounded-full bg-gradient-to-br from-sky-500 from-0% via-primary via-80% to-green-600 to-110% absolute right-1/4 bottom-0"
  ></span>
  <span
    class="w-20 h-20 rounded-full bg-gradient-to-br from-green-500 from-0% via-primary via-80% to-sky-600 to-110% absolute right-1/3 top-1/3"
  ></span>
  <span
    class="w-40 h-40 rounded-full bg-gradient-to-br from-green-500 from-0% via-primary via-80% to-sky-600 to-110% absolute left-0 top-1/3"
  ></span>

  <footer
    class="relative bg-gradient-to-tr from-slate-100/85 to-zinc-200/85 pt-28 rounded-t-3xl backdrop-blur-md"
  >
    <Container className="pb-8 relative overflow-auto">
      <div
        class="grid grid-cols-2 lg:grid-cols-3 lg:items-stretch gap-8 relative"
      >
        <div class="col-span-2 lg:col-span-1 h-auto flex flex-col">
          <div class="h-full">
            <a href="#" class="relative flex items-center gap-3">
              <div class="inline-flex text-xl font-bold text-heading-1">
                Local Leader
              </div>
            </a>
            <Paragraph className={"mt-4"}>
              We make you the #1 tradie in your area — on Google Maps, Google Search, and in reviews.
            </Paragraph>
            <p class="mt-4 text-sm text-heading-3">
              <a href="https://localleader.au" class="hover:text-heading-1 transition">localleader.au</a>
              &nbsp;·&nbsp;
              <a href="mailto:hello@localleader.au" class="hover:text-heading-1 transition">hello@localleader.au</a>
            </p>
          </div>

          <!-- social links -->
          <div class="min-h-max flex items-center gap-4 text-heading-3 mt-8">
            <!-- Facebook -->
            <a href="#" class="transition hover:text-heading-1 hover:scale-105">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
                class="w-5 h-5"
                viewBox="0 0 16 16"
              >
                <path
                  d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"
                ></path>
              </svg>
              <span class="sr-only">Facebook</span>
            </a>

            <!-- LinkedIn -->
            <a href="#" class="transition hover:text-heading-1 hover:scale-105">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
                class="w-5 h-5"
                viewBox="0 0 16 16"
              >
                <path
                  d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"
                ></path>
              </svg>
              <span class="sr-only">LinkedIn</span>
            </a>
          </div>
        </div>

        <GroupFooterNav>
          <FooterNav title={"Quick Links"} navItems={quickLinks} />
          <FooterNav title={"Get in Touch"} navItems={getInTouch} />
        </GroupFooterNav>

        <div class="col-span-2 lg:col-span-1 flex flex-col justify-center">
          <div class="p-6 rounded-2xl bg-gradient-to-br from-indigo-50 to-blue-50 border border-box-border">
            <p class="text-heading-1 font-semibold text-sm">Ready to own your area?</p>
            <p class="text-heading-3 text-sm mt-2">
              Start with a free Google ranking audit — we'll show you exactly where you stand.
            </p>
            <a
              href="/v1/thank-you"
              class="inline-block mt-4 px-5 py-2.5 rounded-full bg-primary text-white text-sm font-medium hover:opacity-90 transition hover:scale-105 shadow-sm"
            >
              Get Your Free Audit
            </a>
          </div>
        </div>
      </div>
    </Container>
    <div class="py-4 relative">
      <Container>
        <div
          class="flex flex-col sm:flex-row justify-between items-center gap-3 text-sm text-heading-3"
        >
          <div>
            &copy; <span id="year"></span> Local Leader. Australian-owned and operated.
          </div>
          <div class="text-xs">
            ABN placeholder · <a href="#" class="hover:text-heading-1 transition">Privacy Policy</a> · <a href="#" class="hover:text-heading-1 transition">Terms</a>
          </div>
        </div>
      </Container>
    </div>
  </footer>
</div>
