---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-AU" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-512.png" />
    <link rel="apple-touch-icon" href="/favicon-512.png" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Local Leader version 5 scaffold for a future landing page build focused on Australian tradies."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;800&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-[#fbfaf7] text-slate-900 antialiased selection:bg-slate-900 selection:text-white">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-sans: "Outfit", system-ui, sans-serif;
    --font-serif: "Source Serif 4", Georgia, serif;
  }

  html {
    font-family: var(--font-sans);
  }

  .font-serif {
    font-family: var(--font-serif);
  }
</style>
